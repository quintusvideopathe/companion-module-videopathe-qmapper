{
  "name": "companion-module-videopathe-qmapper",
  "version": "1.0.0",
  "description": "Bitfocus Companion module for QMapper",
  "main": "dist/main.js",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bitfocus/companion-module-videopathe-qmapper.git"
  },
  "bugs": {
    "url": "https://github.com/bitfocus/companion-module-videopathe-qmapper/issues"
  },
  "engines": {
    "node": "^22.20",
    "yarn": "^4"
  },
  "scripts": {
    "format": "prettier -w .",
    "build": "rimraf dist && run build:main",
    "build:main": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "lint:raw": "eslint",
    "lint": "run lint:raw .",
    "package": "run build && companion-module-build"
  },
  "dependencies": {
    "@companion-module/base": "~1.14.1"
  },
  "devDependencies": {
    "@companion-module/tools": "^2.6.1",
    "@types/node": "^22.19.3",
    "eslint": "^9.39.2",
    "prettier": "^3.7.4",
    "rimraf": "^6.1.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.51.0"
  },
  "prettier": "@companion-module/tools/.prettierrc.json",
  "packageManager": "yarn@4.12.0"
}
